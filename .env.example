# OpenAI GPT-4V key. Leave empty for local fallback demos.
OPENAI_API_KEY=

# Backend database URL.
DATABASE_URL=sqlite+aiosqlite:///./data/colorpal.db

# Allowed frontend origins.
CORS_ALLOW_ORIGINS=http://localhost:5173,http://localhost:8080

# Frontend API base URL.
VITE_API_BASE=http://localhost:8000

# GitHub Discussions login entry.
GITHUB_DISCUSSION_URL=https://github.com/Bamb0oChen/ColorPal/discussions
