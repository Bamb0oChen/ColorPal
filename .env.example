# 视觉模型配置：默认使用 Qwen VL 的 OpenAI-compatible 接口。
# 切 DeepSeek / 自部署 DeepSeek-VL 时，只换下面三项即可；留空则走 HSL 兜底。
VISION_PROVIDER=qwen
VISION_API_KEY=
VISION_API_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions
VISION_MODEL=qwen-vl-max

# OpenAI GPT-4V key. Leave empty for local fallback demos.
OPENAI_API_KEY=

# 小彩文字对话配置；留空时复用上面的 VISION_*，再失败会走本地兜底回复。
CHAT_API_KEY=
CHAT_API_BASE_URL=
CHAT_MODEL=

# 后端连接串；默认 SQLite，无需修改即可起本地
DATABASE_URL=sqlite:///./data/colorpal.db

# Allowed frontend origins.
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8080

# Frontend API base URL.
VITE_API_BASE=http://localhost:8000

# GitHub Discussions login entry.
GITHUB_DISCUSSION_URL=https://github.com/Bamb0oChen/ColorPal/discussions
