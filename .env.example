# 视觉模型配置：默认使用 Qwen VL 的 OpenAI-compatible 接口。
# 切 DeepSeek / 自部署 DeepSeek-VL 时，只换下面三项即可；留空则走 HSL 兜底。
VISION_PROVIDER=qwen
VISION_API_KEY=
VISION_API_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions
VISION_MODEL=qwen-vl-max

# 小彩文字对话配置；留空时复用上面的 VISION_*，再失败会走本地兜底回复。
CHAT_API_KEY=
CHAT_API_BASE_URL=
CHAT_MODEL=

# 后端连接串；默认 SQLite，无需修改即可起本地
DATABASE_URL=sqlite:///./data/colorpal.db

# 允许的前端来源，逗号分隔
CORS_ALLOW_ORIGINS=http://localhost:5173,http://localhost:8080

# 前端连后端的基础 URL（构建时注入，仅 frontend 使用）
VITE_API_BASE=http://localhost:8000
